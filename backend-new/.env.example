# Connect Flow - Microservices Environment Variables
# These are set in docker-compose.yml - this file is for reference only

# ==================== SHARED ====================
JWT_SECRET=your_jwt_secret_key_change_in_production

# ==================== DATABASES ====================
# Auth Database
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
AUTH_DB_PORT=5432

# Post Database
POST_DB_NAME=post_db
POST_DB_USER=post_user
POST_DB_PASSWORD=post_pass
POST_DB_PORT=5433

# Interaction Database
INTERACTION_DB_NAME=interaction_db
INTERACTION_DB_USER=interaction_user
INTERACTION_DB_PASSWORD=interaction_pass
INTERACTION_DB_PORT=5434

# ==================== INFRASTRUCTURE ====================
REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_BROKERS=kafka:9092

CONSUL_HOST=consul
CONSUL_PORT=8500

JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ==================== MICROSERVICES ====================
# Auth Service
AUTH_SERVICE_PORT=5001
AUTH_SERVICE_URL=http://auth-service:5001

# Post Service
POST_SERVICE_PORT=5002
POST_SERVICE_URL=http://post-service:5002

# Interaction Service
INTERACTION_SERVICE_PORT=5003
INTERACTION_SERVICE_URL=http://interaction-service:5003

# Feed Service
FEED_SERVICE_PORT=5004
FEED_SERVICE_URL=http://feed-service:5004

# API Gateway
API_GATEWAY_PORT=4000
